{
  "name": "@uplbtools/discord-bot",
  "version": "0.1.0",
  "private": true,
  "description": "UPLB Tools Discord helper bot — GitHub, notifications, triage",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "register-commands": "bun src/register-commands.ts",
    "register-commands:prod": "node dist/register-commands.js",
    "heroku-postbuild": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./src/test/env-setup.ts src",
    "test:watch": "bun test --preload ./src/test/env-setup.ts --watch src",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check . && bun run typecheck && bun test --preload ./src/test/env-setup.ts src && bun run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.2.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.0",
    "typescript": "^5.8.2"
  }
}
